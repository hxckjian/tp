@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Model MODEL_COLOR_T1
participant ":Model" as Model MODEL_COLOR
participant ":VersionedBlockBook" as VersionedBlockBook MODEL_COLOR
end box

[-> Model : undoBlockBook()
activate Model

Model -> VersionedBlockBook : undo()
activate VersionedBlockBook

VersionedBlockBook -> VersionedBlockBook :resetData(ReadOnlyBlockBook)
VersionedBlockBook --> Model :
deactivate VersionedBlockBook

[<-- Model
deactivate Model

@enduml
