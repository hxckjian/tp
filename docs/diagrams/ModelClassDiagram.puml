@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor MODEL_COLOR
skinparam classBackgroundColor MODEL_COLOR

Package Model as ModelPackage <<Rectangle>>{
Class "<<interface>>\nReadOnlyBlockBook" as ReadOnlyBlockBook
Class "<<interface>>\nReadOnlyUserPrefs" as ReadOnlyUserPrefs
Class "<<interface>>\nModel" as Model
Class BlockBook
Class ModelManager
Class UserPrefs

Class UniqueGamerList
Class Gamer
Class Address
Class Email
Class Name
Class Phone
Class Tag

Class I #FFFFFF
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Model

BlockBook .up.|> ReadOnlyBlockBook

ModelManager .up.|> Model
Model .right.> ReadOnlyUserPrefs
Model .left.> ReadOnlyBlockBook
ModelManager -left-> "1" BlockBook
ModelManager -right-> "1" UserPrefs
UserPrefs .up.|> ReadOnlyUserPrefs

BlockBook *--> "1" UniqueGamerList
UniqueGamerList --> "~* all" Gamer
Gamer *--> Name
Gamer *--> Phone
Gamer *--> Email
Gamer *--> Address
Gamer *--> "*" Tag

Gamer -[hidden]up--> I
UniqueGamerList -[hidden]right-> I

Name -[hidden]right-> Phone
Phone -[hidden]right-> Address
Address -[hidden]right-> Email

ModelManager --> "~* filtered" Gamer
@enduml

